# Used at deploy time for S3 event
AWS_S3_BUCKET=your-bucket-name

# Runtime for Lambdas (provider.environment)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# Nest base URL (no trailing slash). Must be reachable from AWS (public URL or tunnel).
BACKEND_URL=http://localhost:3000
INTERNAL_PIPELINE_SECRET=
